# HTTP port the server listens on. Default: 4318 (the standard OTLP/HTTP port,
# so most exporters work zero-config). In Docker, map this port to the host.
PORT=4318

# Allowed CORS origin(s) for the OTLP ingest (/v1/*) and read API (/api/*)
# endpoints, so browser-based OTLP exporters can post telemetry cross-origin.
# Values: "*" to allow any origin, or a comma-separated list of exact origins.
# Default: * (allow any origin).
# Example (restrict): OTEL_GUI_CORS_ORIGIN=https://app.example.com,http://localhost:5173
OTEL_GUI_CORS_ORIGIN=*

# Maximum number of traces to keep in memory (FIFO eviction).
# Accepted values: integer between 1 and 10000. Default: 1000.
# Requires a server restart to take effect.
OTEL_GUI_MAX_TRACES=1000

# Maximum number of log records to keep in memory (FIFO eviction).
# Accepted values: integer between 1 and 10000. Default: 1000.
# Requires a server restart to take effect.
OTEL_GUI_MAX_LOGS=1000

# Maximum number of distinct metrics kept in memory (counts metric name+service
# combinations, i.e. series collections — NOT individual points). Oldest are
# evicted first when the limit is reached.
# Accepted values: integer between 1 and 10000. Default: 1000.
# Requires a server restart to take effect.
OTEL_GUI_MAX_METRICS=1000

# Maximum number of data points retained per metric series (the per-series ring
# buffer size). This is how much history is kept per series: at a 15s scrape
# interval, 600 points is ~2.5 hours. Oldest points are dropped first. Lower it
# to reduce memory from high-frequency or long-lived series.
# Accepted values: integer between 10 and 10000. Default: 600.
# Requires a server restart to take effect.
OTEL_GUI_MAX_METRIC_POINTS=600

# Model Context Protocol (MCP) endpoint at POST /mcp — lets a local AI agent
# search and fetch the in-memory telemetry (traces, logs, metrics). It is
# restricted to loopback (localhost) clients regardless of this setting.
# Values: 1/true (default, enabled) or 0/false to disable the endpoint.
OTEL_GUI_MCP_ENABLED=1

# Allow non-loopback clients to reach the MCP endpoint. By default it is
# loopback-only, but in a container (e.g. -p 4318:4318) or behind a proxy the
# request arrives via the Docker/proxy gateway address, so loopback-only would
# reject even host-side calls. Set this to 1/true in those deployments, where
# access is controlled at the network / port-mapping layer. (Note: the rest of
# the app is already unauthenticated, so this is a convenience default, not a
# hard security boundary.) Values: 1/true to allow, 0/false (default) loopback-only.
OTEL_GUI_MCP_ALLOW_REMOTE=0

# Interval (ms) for the periodic store-stats debug log (one line to stdout with
# every in-memory collection size, to spot which store is accumulating).
# Accepted values: integer 0-3600000. 0 disables it. Default: 30000 (30s).
OTEL_GUI_STATS_LOG_MS=30000

# Optional local persistence mode.
# Values: memory | pglite. Default: memory.
# Note: pglite requires OTEL_GUI_PERSISTENCE_BACKEND_MODULE to register a backend.
OTEL_GUI_PERSISTENCE_MODE=memory

# Directory path used by PGlite when OTEL_GUI_PERSISTENCE_MODE=pglite.
# Default: .otel-gui/pglite
OTEL_GUI_PERSISTENCE_PATH=.otel-gui/pglite

# Debounce in milliseconds for persistence flush batches.
# Accepted values: integer between 50 and 60000. Default: 750.
OTEL_GUI_PERSISTENCE_FLUSH_MS=750

# Optional module id to load enterprise persistence backends (for open-core builds).
# Relative file paths are resolved from the otel-gui project root (current working directory).
# Example (sibling repo checkout): ../otel-gui-enterprise/enterprise-persistence/dist/register.js
# Example (npm install): @otel-gui/enterprise-persistence/register
OTEL_GUI_PERSISTENCE_BACKEND_MODULE=

# Optional enterprise license key used by private backend modules.
# Example: otg.v1.<payload-base64url>.<signature-base64url>
OTEL_GUI_LICENSE_KEY=

# Optional PEM public key path used by enterprise modules for offline license verification.
OTEL_GUI_LICENSE_PUBLIC_KEY_PATH=

# Optional inline PEM public key (the key contents themselves) used by enterprise
# modules for offline license verification — an alternative to
# OTEL_GUI_LICENSE_PUBLIC_KEY_PATH when mounting a file is inconvenient.
OTEL_GUI_LICENSE_PUBLIC_KEY_PEM=

# Optional allowed clock skew (in seconds) for enterprise license verification.
# Consumed by the private backend module; leave empty to use its default.
OTEL_GUI_LICENSE_CLOCK_SKEW_SEC=
