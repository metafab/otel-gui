{
  "name": "otel-gui",
  "private": true,
  "version": "2.1.0",
  "packageManager": "pnpm@11.13.0",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "lint": "node scripts/run-eslint.mjs .",
    "lint:fix": "node scripts/run-eslint.mjs . --fix",
    "format": "prettier --write .",
    "format:changed": "node scripts/prettier-changed.mjs --write",
    "format:check": "prettier --check .",
    "format:check:changed": "node scripts/prettier-changed.mjs --check",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test --workers=1",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "benchmark:contract": "node scripts/benchmark-contract.mjs",
    "sea:bundle": "node scripts/sea-bundle.mjs",
    "sea:package:binary": "node scripts/sea-package.mjs",
    "sea:package:target": "node scripts/sea-package.mjs",
    "sea:package": "pnpm run sea:bundle && pnpm run sea:package:binary"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.0",
    "@sveltejs/adapter-node": "^5.5.4",
    "@sveltejs/kit": "^2.66.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.4.0",
    "@types/node": "^26.0.0",
    "@vitest/ui": "^4.1.9",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.19.0",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "postject": "^1.0.0-alpha.6",
    "prettier": "^3.8.4",
    "prettier-plugin-svelte": "^4.1.1",
    "svelte": "^5.56.3",
    "svelte-check": "^4.6.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@otel-gui/core": "workspace:*",
    "protobufjs": "^8.6.4"
  }
}
